# Future Board by Project MAKINA — environment variables
#
# Copy this file to .env.local and fill in the values from your Supabase project.
# In Vercel, register these as Environment Variables (Production / Preview / Development).
#
# IMPORTANT:
#   - Use ONLY the public "Publishable" (anon) key here.
#   - NEVER put the service_role / secret key in this file or anywhere in the client.
#   - .env.local is git-ignored and must not be committed.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
